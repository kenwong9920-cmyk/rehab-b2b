---
// 根路径 → 重定向到 /en/
const defaultLocale = 'en';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content="0;url=/{defaultLocale}/" />
  <link rel="canonical" href="/{defaultLocale}/" />
  <title>Redirecting...</title>
</head>
<body>
  <p>Redirecting to <a href="/{defaultLocale}/">English site</a>...</p>
</body>
</html>
