---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import { useTranslations } from '@/utils/i18n';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'ko' } },
    { params: { locale: 'ja' } },
    { params: { locale: 'ar' } },
  ];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale!);

const downloads = [
  { icon: '📄', title: 'Product Catalog 2026', desc: 'Complete product catalog with specifications and pricing guide.', size: 'PDF · 8.2 MB', slug: 'product-catalog-2026' },
  { icon: '📋', title: 'Company Profile', desc: 'Company introduction, certifications, and factory overview.', size: 'PDF · 3.1 MB', slug: 'company-profile' },
];
---

<BaseLayout title="Downloads" description="Download product catalogs and resources" locale={locale!}>
  <section class="bg-neutral-50">
    <div class="container-main py-16">
      <div class="text-center mb-12">
        <h1>Downloads</h1>
        <p class="mt-3 text-neutral-600">Download product catalogs, company profiles, and technical documentation.</p>
      </div>

      <div class="max-w-2xl mx-auto space-y-4">
        {downloads.map((d) => (
          <div class="flex items-center gap-5 bg-white rounded-xl border border-neutral-200 p-5 hover:border-primary-300 hover:shadow-sm transition-all group">
            <div class="text-3xl shrink-0">{d.icon}</div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">{d.title}</h3>
              <p class="text-sm text-neutral-600 mt-1">{d.desc}</p>
              <span class="text-xs text-neutral-400 mt-1 block">{d.size}</span>
            </div>
            <a href={`/${locale}/get-quote/?source=download&file=${encodeURIComponent(d.title)}`} class="btn-primary btn-sm shrink-0">
              Download
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Need Custom Documentation?"
    subtitle="Contact us for tailored technical specifications for your procurement requirements."
    ctaText="Contact Us →"
    ctaHref={`/${locale}/contact/`}
    variant="primary"
  />
</BaseLayout>
