---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/utils/i18n';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'ko' } },
    { params: { locale: 'ja' } },
    { params: { locale: 'ar' } },
  ];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale!);

const downloads = [
  {
    icon: '📄',
    title: 'Product Catalog 2026',
    desc: 'Complete product catalog with specifications and pricing guide.',
    size: 'PDF · 8.2 MB',
    slug: 'product-catalog-2026',
  },
  {
    icon: '📋',
    title: 'Company Profile',
    desc: 'Company introduction, certifications, and factory overview.',
    size: 'PDF · 3.1 MB',
    slug: 'company-profile',
  },
];
---

<BaseLayout title={t('downloads.modalTitle', 'Download Resources')} description={t('downloads.modalSubtitle', '')} locale={locale!}>
  <section class="bg-neutral-50 min-h-[60vh]">
    <div class="container-main py-16 max-w-lg mx-auto">
      <div class="text-center mb-8">
        <span class="text-4xl block mb-3">📥</span>
        <h1 class="text-2xl font-bold text-neutral-900 mb-2">
          {t('downloads.modalTitle', 'Download Resources')}
        </h1>
        <p class="text-neutral-600 text-sm">
          {t('downloads.modalSubtitle', 'Enter your email to receive our product catalog and company profile instantly.')}
        </p>
      </div>

      {/* Download items */}
      <div class="space-y-3 mb-6">
        {downloads.map((d) => (
          <div class="flex items-center gap-4 bg-white rounded-xl p-4 border border-neutral-200 shadow-sm">
            <span class="text-2xl shrink-0">{d.icon}</span>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-neutral-900">{d.title}</h3>
              <p class="text-xs text-neutral-500 mt-0.5">{d.desc}</p>
              <span class="text-xs text-neutral-400 mt-1 inline-block">{d.size}</span>
            </div>
          </div>
        ))}
      </div>

      {/* Email form */}
      <form
        id="downloads-page-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        class="space-y-3"
      >
        <input type="hidden" name="access_key" value="f76d4663-7486-4058-a0b7-8c9e11cb5f79" />
        <input type="hidden" name="subject" value="Download Request — JinDa Rehab Medical" />
        <input type="hidden" name="from_name" value="JinDa Rehab Downloads" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
        <input type="hidden" name="redirect" value="false" />

        {/* Tracking fields */}
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="source" value="downloads-page" />
        <input type="hidden" name="download_material" value="product-catalog-2026,company-profile" />

        <div>
          <input
            type="email"
            name="email"
            required
            placeholder={t('downloads.emailPlaceholder', 'your@email.com')}
            class="w-full px-4 py-3 border border-neutral-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
          />
        </div>

        <button
          type="submit"
          id="downloads-page-submit"
          class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-colors text-sm"
        >
          {t('downloads.submitButton', 'Send Me the Files')} →
        </button>
      </form>

      <p id="downloads-page-privacy" class="text-xs text-neutral-400 text-center mt-4">
        {t('downloads.privacy', "We respect your privacy. Your email will never be shared.")}
      </p>

      {/* Success state (hidden) */}
      <div id="downloads-page-success" class="text-center py-8" style="display:none">
        <span class="text-5xl block mb-4">✅</span>
        <h3 class="text-xl font-bold text-neutral-900 mb-2">
          {t('downloads.successTitle', 'Check Your Inbox!')}
        </h3>
        <p class="text-sm text-neutral-600 mb-6">
          {t('downloads.successMessage', "We've sent the download links to your email. You can also download directly below:")}
        </p>
        <div class="space-y-2 mb-6">
          {downloads.map((d) => (
            <a
              href={`/downloads/${d.slug}.pdf`}
              class="flex items-center gap-3 bg-green-50 hover:bg-green-100 rounded-xl p-4 border border-green-200 transition-colors no-underline text-left"
              download
            >
              <span class="text-2xl shrink-0">{d.icon}</span>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-semibold text-green-800 block">{d.title}</span>
                <span class="text-xs text-green-600">{d.size}</span>
              </div>
              <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('downloads-page-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('downloads-page-submit') as HTMLButtonElement | null;
  const successEl = document.getElementById('downloads-page-success');
  const privacyEl = document.getElementById('downloads-page-privacy');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    const originalText = submitBtn.textContent || 'Send';
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;

    try {
      const formData = new FormData(form);

      // Append client-side tracking fields
      formData.append('page_url', window.location.href);
      const searchParams = new URLSearchParams(window.location.search);
      ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach((p) => {
        const val = searchParams.get(p);
        if (val) formData.append(p, val);
      });

      const res = await fetch(form.action, { method: 'POST', body: formData });

      if (res.ok) {
        form.style.display = 'none';
        if (privacyEl) privacyEl.style.display = 'none';
        if (successEl) successEl.style.display = '';
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      if (submitBtn) {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
      alert('Something went wrong. Please try again or email us at info@jdrehab.com');
    }
  });
</script>
