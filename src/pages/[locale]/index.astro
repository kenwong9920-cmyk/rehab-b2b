---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import FeaturesGrid from '@/components/FeaturesGrid.astro';
import { useTranslations } from '@/utils/i18n';
import { SITE, PRODUCT_CATEGORIES } from '@/utils/constants';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'ko' } },
    { params: { locale: 'ja' } },
  ];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale!);

// Hero 轮动图（4张）
const heroImages = [
  '/images/hero1-clean-product-right-final.webp',
  '/images/1780219316.webp',
  '/images/Gemini_Generated_Image_a6ak9ja6ak9ja6ak.webp',
  '/images/hero3.webp',
];

// Why Us features
const whyUsFeatures = [
  {
    icon: '🏭',
    title: t('home.certifiedFactory'),
    description: t('home.certifiedFactoryDesc'),
  },
  {
    icon: '🔧',
    title: t('home.oemService'),
    description: t('home.oemServiceDesc'),
  },
  {
    icon: '🚢',
    title: t('home.globalShipping'),
    description: t('home.globalShippingDesc'),
  },
  {
    icon: '✅',
    title: t('home.qualityControl'),
    description: t('home.qualityControlDesc'),
  },
];

// 精选产品 — 从内容集合中选三个代表产品（每类目一个）
const allProducts = await getCollection('products', (entry) => entry.id.startsWith(`${locale}/`));
const featuredSlugs = ['lightweight-carbon-fiber-folding-cane', 'white-extra-wide-heavy-duty-shower-chair', 'flip-back-commode-chair-anti-slip'];
const featuredProducts = featuredSlugs
  .map(slug => allProducts.find(p => p.id === `${locale}/${slug}`))
  .filter(Boolean)
  .map(p => ({
    title: p!.data.title,
    description: p!.data.description,
    image: p!.data.image,
    href: `/${locale}/products/${p!.id.split('/').pop()}/`,
    category: t(`categories.${PRODUCT_CATEGORIES.find(c => c.slug === p!.data.category)?.nameKey.split('.').pop() || 'walkingAids'}`),
    moq: p!.data.moq,
  }));

// 客户品牌（图标）
const clientLogos = ['MediCare', 'HealthPlus', 'OrthoLife', 'RehaWorld', 'MedSupply', 'CareFirst'];

// Schema
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}/og-image.png`,
  description: t('home.heroSubtitle'),
  email: SITE.email,
  telephone: SITE.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.province,
    addressCountry: 'CN',
  },
  sameAs: [
    SITE.social.linkedin,
    SITE.social.instagram,
  ].filter(Boolean),
};
---

<BaseLayout title={t('site.name')} description={t('home.heroSubtitle')} locale={locale!} schema={schema}>
  <!-- ===== Hero Carousel ===== -->
  <section class="relative bg-gradient-to-br from-primary-700 via-primary-600 to-primary-800 text-white overflow-hidden">
    <!-- Carousel Slides -->
    {heroImages.map((img, i) => (
      <div class={`hero-slide absolute inset-0 opacity-[0.85] transition-opacity duration-1000 ${i === 0 ? 'opacity-[0.85]' : 'opacity-0'}`} data-index={i}>
        <img
          src={img}
          alt=""
          class="w-full h-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
          width="1600"
          height="900"
        />
      </div>
    ))}
    <div class="absolute inset-0 bg-gradient-to-t from-primary-900/20 to-transparent"></div>

    <!-- Content -->
    <div class="container-main relative py-24 md:py-36">
      <div class="max-w-3xl">
        <h1 class="text-white mb-6 leading-tight text-2xl md:text-3xl lg:text-4xl max-w-2xl">
          {t('home.heroTitle')}
        </h1>
        <p class="text-base md:text-lg text-white/80 leading-relaxed mb-8 max-w-xl">
          {t('home.heroSubtitle')}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`/${locale}/get-quote/`} class="btn-accent text-lg">
            {t('home.heroCTA')} →
          </a>
          <a href={`/${locale}/products/`} class="btn-outline text-lg !border-white !text-white hover:!bg-white hover:!text-primary-700">
            {t('home.heroCTA2')}
          </a>
        </div>
      </div>

      <!-- Carousel Dots -->
      <div class="flex gap-2 mt-16" id="heroDots">
        {heroImages.map((_, i) => (
          <button class={`hero-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white w-8' : 'bg-white/40 hover:bg-white/60'}`} data-index={i} aria-label={`Slide ${i + 1}`}></button>
        ))}
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap gap-6 mt-16 text-sm text-white/70">
        {SITE.certifications.map((cert) => (
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            {cert}
          </span>
        ))}
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          {SITE.exportCountries}+ Countries Served
        </span>
      </div>
    </div>
  </section>

  <!-- ===== Company Strength Snapshot ===== -->
  <section class="bg-white border-y border-neutral-100">
    <div class="container-main py-10">
      <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
        <!-- Left: Factory thumbnail -->
        <a href={`/${locale}/about/`} class="shrink-0 w-full lg:w-64 aspect-video rounded-lg overflow-hidden bg-neutral-200 relative group">
          <img
            src="https://img.youtube.com/vi/zotxhYfMRBY/maxresdefault.jpg"
            alt="JinDa Rehab Medical Factory"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            width="640"
            height="360"
          />
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors flex items-center justify-center">
            <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center group-hover:scale-110 transition-transform">
              <svg class="w-5 h-5 text-primary-600 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </a>

        <!-- Right: Stats + trust -->
        <div class="flex-1 text-center lg:text-left">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 mb-2">
            ISO 13485 Certified Manufacturer Since 2010
          </h2>
          <p class="text-sm text-neutral-600 mb-6 max-w-xl">
            We operate a 15,000 m² facility in Guangdong, China — equipped with modern production lines, in-house R&D, and rigorous quality control at every stage. Every product ships with full traceability and CE / FDA documentation.
          </p>

          <!-- Key stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
            <div class="text-center lg:text-left">
              <div class="text-2xl font-bold text-primary-600">{new Date().getFullYear() - SITE.foundedYear}+</div>
              <div class="text-xs text-neutral-500 mt-1">Years Experience</div>
            </div>
            <div class="text-center lg:text-left">
              <div class="text-2xl font-bold text-primary-600">{SITE.factoryArea}</div>
              <div class="text-xs text-neutral-500 mt-1">Factory Area</div>
            </div>
            <div class="text-center lg:text-left">
              <div class="text-2xl font-bold text-primary-600">{SITE.employees}</div>
              <div class="text-xs text-neutral-500 mt-1">Team Members</div>
            </div>
            <div class="text-center lg:text-left">
              <div class="text-2xl font-bold text-primary-600">{SITE.exportCountries}+</div>
              <div class="text-xs text-neutral-500 mt-1">Countries Served</div>
            </div>
          </div>

          <!-- Cert badges + CTA -->
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3">
            {SITE.certifications.map((cert) => (
              <span class="inline-flex items-center gap-1 text-xs font-medium bg-green-50 text-green-700 px-2.5 py-1 rounded-full border border-green-200">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {cert}
              </span>
            ))}
            <a href={`/${locale}/about/`} class="text-sm font-medium text-primary-600 hover:text-primary-700 ml-2">
              About Our Factory →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Product Categories ===== -->
  <section class="container-main section-padding">
    <div class="text-center mb-12">
      <h2>{t('home.categoriesTitle')}</h2>
      <p class="mt-3 text-neutral-500 max-w-2xl mx-auto">
        From walking aids to physiotherapy equipment — we provide complete rehabilitation solutions for B2B partners worldwide.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {PRODUCT_CATEGORIES.map((cat) => (
        <a
          href={`/${locale}/products/${cat.slug}/`}
          class="group block p-6 bg-white rounded-xl border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all duration-300 no-underline"
        >
          <div class="text-4xl md:text-5xl mb-4 group-hover:scale-110 transition-transform duration-300 inline-block">
            {cat.icon}
          </div>
          <h3 class="text-lg font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors mb-2">
            {t(cat.nameKey)}
          </h3>
          <p class="text-sm text-neutral-600 leading-relaxed">
            {t(cat.descriptionKey)}
          </p>
          <span class="inline-flex items-center text-sm font-medium text-primary-600 mt-4 group-hover:gap-2 transition-all">
            {t('common.learnMore')} →
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== Why Choose Us ===== -->
  <section class="bg-neutral-50">
    <div class="container-main section-padding">
      <div class="text-center mb-12">
        <h2>{t('home.whyUsTitle')}</h2>
      </div>
      <FeaturesGrid features={whyUsFeatures} columns={4} />
    </div>
  </section>

  <!-- ===== Factory / Banner Image ===== -->
  <section class="w-full">
    <img
      src="/images/factory-banner.webp"
      alt="JinDa Rehab Medical Factory and Products Showcase"
      class="w-full h-auto object-cover"
      loading="lazy"
      width="1920"
      height="800"
    />
  </section>

  <!-- ===== Featured Products ===== -->
  <section class="container-main section-padding">
    <div class="text-center mb-12">
      <h2>{t('home.featuredProducts')}</h2>
      <p class="mt-3 text-neutral-500">
      <p class="mt-3 text-neutral-500">
        Our most popular rehabilitation equipment trusted by B2B clients worldwide.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredProducts.map((product) => (
        <div class="bg-white rounded-xl border border-neutral-200 overflow-hidden hover:shadow-lg hover:border-primary-200 transition-all duration-300 group flex flex-col">
          <a href={product.href} class="block aspect-square overflow-hidden bg-white">
            <img
              src={product.image}
              alt={product.title}
              class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500 p-4"
              loading="lazy"
              width="400"
              height="400"
            />
          </a>
          <div class="p-5 flex flex-col flex-1">
            {product.category && <span class="text-xs font-medium text-primary-600 uppercase tracking-wide mb-2">{product.category}</span>}
            <a href={product.href} class="no-underline">
              <h3 class="text-lg font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors mb-2">
                {product.title}
              </h3>
            </a>
            <p class="text-sm text-neutral-600 leading-relaxed flex-1 mb-4">{product.description}</p>
            <div class="flex items-center justify-between pt-3 border-t border-neutral-100">
              <span class="text-xs text-neutral-500">MOQ: {product.moq}</span>
              <a href={`/${locale}/get-quote/?product=${encodeURIComponent(product.title)}`} class="btn-primary btn-sm">
                Get Quote
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href={`/${locale}/products/`} class="btn-outline">
        {t('common.viewAll')} {t('nav.products')} →
      </a>
    </div>
  </section>

  <!-- ===== Client Logo Wall ===== -->
  <section class="bg-neutral-50">
    <div class="container-main py-16">
      <p class="text-center text-sm font-medium text-neutral-400 uppercase tracking-wider mb-8">
        Trusted by Healthcare Companies Worldwide
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 opacity-50">
        {clientLogos.map((logo) => (
          <span class="text-2xl font-bold text-neutral-400">{logo}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <CTASection
    title={t('home.ctaTitle')}
    subtitle={t('home.ctaSubtitle')}
    ctaText={t('home.ctaButton')}
    ctaHref={`/${locale}/get-quote/`}
    variant="primary"
  />
</BaseLayout>

<script>
  // Hero Carousel
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  let currentSlide = 0;
  const totalSlides = slides.length;
  let autoplayTimer: ReturnType<typeof setInterval>;

  function goToSlide(index: number) {
    slides.forEach((s, i) => {
      if (i === index) {
        (s as HTMLElement).style.opacity = '0.85';
      } else {
        (s as HTMLElement).style.opacity = '0';
      }
    });
    dots.forEach((d, i) => {
      if (i === index) {
        d.classList.add('bg-white', 'w-8');
        d.classList.remove('bg-white/40', 'w-2.5');
      } else {
        d.classList.remove('bg-white', 'w-8');
        d.classList.add('bg-white/40', 'w-2.5');
      }
    });
    currentSlide = index;
  }

  function nextSlide() {
    goToSlide((currentSlide + 1) % totalSlides);
  }

  // Dot click handlers
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt((dot as HTMLElement).dataset.index || '0');
      goToSlide(idx);
      resetAutoplay();
    });
  });

  // Autoplay
  function startAutoplay() {
    autoplayTimer = setInterval(nextSlide, 5500);
  }

  function resetAutoplay() {
    clearInterval(autoplayTimer);
    startAutoplay();
  }

  if (totalSlides > 1) {
    startAutoplay();
  }
</script>
