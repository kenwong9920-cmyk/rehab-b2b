---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import { useTranslations } from '@/utils/i18n';
import { SITE } from '@/utils/constants';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'ko' } },
    { params: { locale: 'ja' } },
    { params: { locale: 'ar' } },
  ];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale!);

const facilities = [
  { icon: '🏗️', title: t('factory.facility1Title'), desc: t('factory.facility1Desc') },
  { icon: '🤖', title: t('factory.facility2Title'), desc: t('factory.facility2Desc') },
  { icon: '🔬', title: t('factory.facility3Title'), desc: t('factory.facility3Desc') },
  { icon: '📦', title: t('factory.facility4Title'), desc: t('factory.facility4Desc') },
];

const qualitySteps = [
  { step: '01', title: t('factory.quality1Title'), desc: t('factory.quality1Desc') },
  { step: '02', title: t('factory.quality2Title'), desc: t('factory.quality2Desc') },
  { step: '03', title: t('factory.quality3Title'), desc: t('factory.quality3Desc') },
  { step: '04', title: t('factory.quality4Title'), desc: t('factory.quality4Desc') },
];
---

<BaseLayout title={t('factory.title')} description={t('factory.subtitle')} locale={locale!}>
  <section class="bg-neutral-900 text-white">
    <div class="container-main py-20 text-center max-w-3xl">
      <h1 class="text-white mb-4">{t('factory.title')}</h1>
      <p class="text-xl text-white/70">{t('factory.subtitle')}</p>
    </div>
  </section>

  <section class="container-main section-padding">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2>{t('factory.excellenceTitle')}</h2>
      <p class="mt-4 text-neutral-600">{t('factory.excellenceDesc')}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {facilities.map((f) => (
        <div class="flex gap-4 p-6 bg-neutral-50 rounded-xl">
          <div class="text-3xl shrink-0">{f.icon}</div>
          <div>
            <h3 class="text-lg mb-1">{f.title}</h3>
            <p class="text-sm text-neutral-600">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== Factory Photo Gallery ===== -->
  <section class="container-main section-padding">
    <div class="text-center mb-12">
      <h2>{t('factory.factoryGalleryTitle')}</h2>
      <p class="mt-3 text-neutral-500 max-w-2xl mx-auto">{t('factory.factoryGallerySubtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 max-w-6xl mx-auto">
      {[
        { img: '/images/factory-production-line.webp', label: t('factory.factoryLabel1') },
        { img: '/images/factory-quality-testing.webp', label: t('factory.factoryLabel2') },
        { img: '/images/factory-warehouse.webp', label: t('factory.factoryLabel3') },
        { img: '/images/factory-welding.webp', label: t('factory.factoryLabel4') },
        { img: '/images/factory-packaging.webp', label: t('factory.factoryLabel5') },
        { img: '/images/factory-rd-lab.webp', label: t('factory.factoryLabel6') },
      ].map((photo) => (
        <div class="group">
          <div class="aspect-[4/3] rounded-xl overflow-hidden bg-neutral-200 border border-neutral-200 group-hover:border-primary-300 transition-colors">
            <img src={photo.img} alt={`JinDa Rehab Medical — ${photo.label}`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="640" height="480" />
          </div>
          <p class="mt-2 text-sm font-medium text-neutral-600 text-center">{photo.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Quality Control -->
  <section class="bg-neutral-50">
    <div class="container-main section-padding">
      <h2 class="text-center mb-12">{t('factory.qualityTitle')}</h2>
      <div class="max-w-3xl mx-auto">
        {qualitySteps.map((q, i) => (
          <div class="flex gap-6 pb-8 relative">
            {i < 3 && <div class="absolute left-[27px] top-12 bottom-0 w-px bg-neutral-300"></div>}
            <div class="w-14 h-14 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold text-lg shrink-0">{q.step}</div>
            <div>
              <h3 class="text-lg mb-1">{q.title}</h3>
              <p class="text-sm text-neutral-600">{q.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title={t('factory.ctaTitle')}
    subtitle={t('factory.ctaSubtitle')}
    ctaText={t('factory.ctaText')}
    ctaHref={`/${locale}/contact/`}
    variant="primary"
  />
</BaseLayout>
