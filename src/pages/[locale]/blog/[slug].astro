---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/utils/i18n';
import { getCollection } from 'astro:content';
import { SITE } from '@/utils/constants';

// 使用 import.meta.glob 加载所有博客文章（用于渲染 Markdown 内容）
const blogModules = import.meta.glob('@/content/blog/**/*.md', { eager: true });

export async function getStaticPaths() {
  const locales = ['en', 'fr', 'de', 'es', 'ko', 'ja', 'ar'];
  const paths: { params: { locale: string; slug: string } }[] = [];

  for (const locale of locales) {
    const posts = await getCollection('blog', (entry) =>
      entry.id.startsWith(`${locale}/`)
    );
    for (const post of posts) {
      const slug = post.id.split('/').pop()!;
      paths.push({ params: { locale, slug } });
    }
  }

  return paths;
}

const { locale, slug } = Astro.params;
const { t } = useTranslations(locale!);

const posts = await getCollection('blog', (entry) =>
  entry.id === `${locale}/${slug}`
);
const post = posts[0];

if (!post) {
  return Astro.redirect(`/${locale}/blog/`);
}

// 通过 glob import 获取渲染后的 Content 组件
const blogKey = `/src/content/blog/${locale}/${slug}.md`;
const blogModule = blogModules[blogKey] as { Content?: import('astro').MarkdownInstance<unknown>['Content']; compiledContent?: () => string } | undefined;

// 获取渲染后的 HTML（回退到纯文本）
let contentHtml = '';
if (blogModule?.compiledContent) {
  contentHtml = blogModule.compiledContent();
}

// Related posts
const relatedPosts = (await getCollection('blog', (entry) =>
  entry.id.startsWith(`${locale}/`) && entry.id !== `${locale}/${slug}`
)).slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: post.data.title,
      description: post.data.description,
      image: post.data.image,
      datePublished: post.data.date.toISOString(),
      author: { '@type': 'Organization', name: post.data.author },
      publisher: {
        '@type': 'Organization',
        name: SITE.name,
        logo: { '@type': 'ImageObject', url: `${SITE.url}/og-image.png` },
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('nav.home'), item: `${SITE.url}/${locale}/` },
        { '@type': 'ListItem', position: 2, name: t('nav.blog'), item: `${SITE.url}/${locale}/blog/` },
        { '@type': 'ListItem', position: 3, name: post.data.title },
      ],
    },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  locale={locale!}
  image={post.data.image || '/og-image.png'}
  schema={schema}
>
  <article class="container-main section-padding">
    <div class="max-w-3xl mx-auto">
      <header class="mb-10">
        {post.data.category && (
          <span class="inline-block text-sm font-medium text-primary-600 uppercase tracking-wide mb-4">
            {post.data.category}
          </span>
        )}
        <h1>{post.data.title}</h1>
        <div class="flex items-center gap-4 mt-4 text-sm text-neutral-500">
          <span>{post.data.author}</span>
          <span>·</span>
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        </div>
      </header>

      {post.data.image && (
        <div class="aspect-[2/1] rounded-xl overflow-hidden bg-neutral-100 mb-10">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-full object-cover"
            width="1200"
            height="600"
          />
        </div>
      )}

      {/* Rendered Markdown Content */}
      <div class="prose prose-neutral max-w-none prose-headings:font-heading prose-headings:font-bold prose-a:text-primary-600 prose-img:rounded-xl prose-table:border prose-table:overflow-x-auto prose-th:border prose-th:border-neutral-300 prose-th:bg-neutral-50 prose-th:px-4 prose-th:py-2 prose-td:border prose-td:border-neutral-200 prose-td:px-4 prose-td:py-2">
        <Fragment set:html={contentHtml} />
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-neutral-200">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-neutral-100 text-neutral-600 px-3 py-1.5 rounded-full">{tag}</span>
          ))}
        </div>
      )}

      <div class="mt-10 bg-primary-600 text-white rounded-xl p-8 text-center">
        <h3 class="text-white mb-2">Need Rehabilitation Equipment?</h3>
        <p class="text-white/80 mb-6 max-w-md mx-auto">
          Contact us for a free consultation and quote. Our team responds within 24 hours.
        </p>
        <a href={`/${locale}/get-quote/`} class="btn-white">
          {t('nav.getQuote')} →
        </a>
      </div>
    </div>
  </article>

  {relatedPosts.length > 0 && (
    <section class="bg-neutral-50">
      <div class="container-main py-16">
        <h2 class="text-center mb-8">{t('blog.relatedPosts')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {relatedPosts.map((rp) => {
            const rpSlug = rp.id.split('/').pop();
            return (
              <a
                href={`/${locale}/blog/${rpSlug}/`}
                class="group bg-white rounded-xl border border-neutral-200 overflow-hidden hover:shadow-md transition-all no-underline"
              >
                {rp.data.image && (
                  <div class="aspect-[16/9] overflow-hidden bg-neutral-100">
                    <img src={rp.data.image} alt={rp.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="400" height="225" />
                  </div>
                )}
                <div class="p-5">
                  <h4 class="text-base font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors line-clamp-2">{rp.data.title}</h4>
                  <span class="text-xs text-neutral-400 mt-2 block">{formatDate(rp.data.date)}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
