---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/utils/i18n';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'ko' } },
    { params: { locale: 'ja' } },
  ];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale!);

const allPosts = await getCollection('blog', (entry) =>
  entry.id.startsWith(`${locale}/`)
);

// Sort by date descending
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get unique categories
const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))];
const activeCategory = Astro.url.searchParams.get('category') || '';
const filteredPosts = activeCategory
  ? posts.filter((p) => p.data.category === activeCategory)
  : posts;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={t('blog.title')} description={t('blog.subtitle')} locale={locale!}>
  <div class="container-main section-padding">
    <div class="text-center mb-12">
      <h1>{t('blog.title')}</h1>
      <p class="mt-3 text-neutral-600">{t('blog.subtitle')}</p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a
        href={`/${locale}/blog/`}
        class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${
          !activeCategory ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600 hover:bg-neutral-200'
        }`}
      >
        All Posts
      </a>
      {categories.map((cat) => (
        <a
          href={`/${locale}/blog/?category=${encodeURIComponent(cat || '')}`}
          class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${
            activeCategory === cat ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600 hover:bg-neutral-200'
          }`}
        >
          {cat}
        </a>
      ))}
    </div>

    <!-- Posts Grid -->
    {filteredPosts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-neutral-500 text-lg">No articles found in this category yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {filteredPosts.map((post) => {
          const slug = post.id.split('/').pop();
          return (
            <article class="bg-white rounded-xl border border-neutral-200 overflow-hidden hover:shadow-lg hover:border-primary-200 transition-all duration-300 group flex flex-col">
              {post.data.image && (
                <a href={`/${locale}/blog/${slug}/`} class="block aspect-square overflow-hidden bg-white">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500 p-4"
                    loading="lazy"
                    width="600"
                    height="600"
                  />
                </a>
              )}
              <div class="p-6 flex flex-col flex-1">
                {post.data.category && (
                  <span class="text-xs font-medium text-primary-600 uppercase tracking-wide mb-2">
                    {post.data.category}
                  </span>
                )}
                <a href={`/${locale}/blog/${slug}/`} class="no-underline">
                  <h2 class="text-lg font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors mb-2 line-clamp-2">
                    {post.data.title}
                  </h2>
                </a>
                <p class="text-sm text-neutral-600 leading-relaxed flex-1 mb-4 line-clamp-3">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between pt-4 border-t border-neutral-100 text-xs text-neutral-400">
                  <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                  <a href={`/${locale}/blog/${slug}/`} class="text-primary-600 font-medium hover:text-primary-700">
                    {t('blog.readMore')} →
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    <!-- CTA -->
    <div class="mt-16 text-center bg-neutral-50 rounded-2xl p-10">
      <h3 class="mb-2">Have a Topic You'd Like Us to Cover?</h3>
      <p class="text-neutral-600 mb-6 max-w-xl mx-auto">
        We regularly publish guides and insights for rehabilitation equipment buyers. Let us know what topics interest you.
      </p>
      <a href={`/${locale}/contact/`} class="btn-primary">
        {t('nav.contact')} →
      </a>
    </div>
  </div>
</BaseLayout>
