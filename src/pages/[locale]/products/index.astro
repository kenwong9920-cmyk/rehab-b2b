---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/utils/i18n';
import { PRODUCT_CATEGORIES } from '@/utils/constants';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'ko' } },
    { params: { locale: 'ja' } },
    { params: { locale: 'ar' } },
  ];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale!);

// 获取当前语言的产品
const allProducts = await getCollection('products', (entry) => {
  return entry.id.startsWith(`${locale}/`);
});

// 按 order 排序
const sortedProducts = [...allProducts].sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

// SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t('nav.products'),
  description: `All rehabilitation products by ${t('site.name')}`,
};
---

<BaseLayout title={t('nav.products')} description={`Premium rehabilitation equipment wholesale — walking aids, shower chairs, commode chairs, walkers and toilet safety products. ISO 13485 certified manufacturer, CE & FDA approved. Quality rehabilitation equipment for B2B buyers worldwide.`} locale={locale!} schema={schema}>
  <div class="container-main section-padding">
    <!-- Header -->
    <div class="mb-10">
      <h1>{t('nav.products')}</h1>
      <p class="mt-3 text-neutral-600">
        <span id="productCount">{allProducts.length}</span> products available for wholesale and OEM customization
      </p>
    </div>

    <!-- Category Filter Tabs -->
    <div class="flex flex-wrap gap-2 mb-10" id="categoryFilters">
      <button
        data-category=""
        class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all bg-primary-600 text-white"
      >
        {t('product.allProducts')}
      </button>
      {PRODUCT_CATEGORIES.map((cat) => (
        <button
          data-category={cat.slug}
          class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all bg-neutral-100 text-neutral-600 hover:bg-neutral-200"
        >
          {cat.icon} {t(cat.nameKey)}
        </button>
      ))}
    </div>

    <!-- Results -->
    <div id="noProducts" class="text-center py-20 hidden">
      <p class="text-neutral-500 text-lg">No products found in this category yet.</p>
      <button data-category="" class="filter-btn btn-outline mt-4 inline-flex">
        {t('product.allProducts')}
      </button>
    </div>

    <div id="productGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedProducts.map((product) => (
        <div class="product-card bg-white rounded-xl border border-neutral-200 overflow-hidden hover:shadow-lg hover:border-primary-200 transition-all duration-300 group flex flex-col" data-category={product.data.category}>
            <a href={`/${locale}/products/${product.id.split('/').pop()}/`} class="block aspect-square overflow-hidden bg-white">
              <img
                src={product.data.image}
                alt={product.data.title}
                class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500 p-4"
                loading="lazy"
                width="400"
                height="400"
              />
            </a>
            <div class="p-5 flex flex-col flex-1">
              {product.data.category && (
                <span class="text-xs font-medium text-primary-600 uppercase tracking-wide mb-2">
                  {t(`categories.${PRODUCT_CATEGORIES.find(c => c.slug === product.data.category)?.nameKey.split('.').pop() || ''}`)}
                </span>
              )}
              <a href={`/${locale}/products/${product.id.split('/').pop()}/`} class="no-underline">
                <h3 class="text-lg font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors mb-2">
                  {product.data.title}
                </h3>
              </a>
              <p class="text-sm text-neutral-600 leading-relaxed flex-1 mb-4 line-clamp-2">
                {product.data.description}
              </p>
              <div class="flex items-center justify-between pt-3 border-t border-neutral-100">
                {product.data.moq && <span class="text-xs text-neutral-500">MOQ: {product.data.moq}</span>}
                <a href={`/${locale}/products/${product.id.split('/').pop()}/`} class="btn-primary btn-sm ml-auto">
                  View Details
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center bg-neutral-50 rounded-2xl p-10">
      <h3 class="mb-2">Need a Custom Solution?</h3>
      <p class="text-neutral-600 mb-6 max-w-xl mx-auto">
        We provide OEM and ODM services to tailor our products to your specific requirements.
        Contact us for a personalized quote.
      </p>
      <a href={`/${locale}/get-quote/`} class="btn-accent">
        {t('nav.getQuote')} →
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // Client-side category filtering
  const filterBtns = document.querySelectorAll('.filter-btn');
  const productCards = document.querySelectorAll('.product-card');
  const noProducts = document.getElementById('noProducts');
  const productCountEl = document.getElementById('productCount');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).dataset.category || '';

      // Update active button style
      filterBtns.forEach(b => {
        b.classList.remove('bg-primary-600', 'text-white');
        b.classList.add('bg-neutral-100', 'text-neutral-600');
      });
      btn.classList.add('bg-primary-600', 'text-white');
      btn.classList.remove('bg-neutral-100', 'text-neutral-600');

      // Filter products
      let visibleCount = 0;
      productCards.forEach(card => {
        const cardCategory = (card as HTMLElement).dataset.category;
        if (!category || cardCategory === category) {
          (card as HTMLElement).style.display = '';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      // Show/hide empty state
      if (noProducts) {
        (noProducts as HTMLElement).classList.toggle('hidden', visibleCount > 0);
      }

      // Update count
      if (productCountEl) {
        productCountEl.textContent = String(visibleCount);
      }
    });
  });
</script>
