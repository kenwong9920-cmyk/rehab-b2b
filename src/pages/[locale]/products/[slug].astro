---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/utils/i18n';
import { SITE, PRODUCT_CATEGORIES } from '@/utils/constants';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const locales = ['en', 'fr', 'de', 'es'];
  const paths: { params: { locale: string; slug: string } }[] = [];

  for (const locale of locales) {
    const products = await getCollection('products', (entry) =>
      entry.id.startsWith(`${locale}/`)
    );
    for (const product of products) {
      const slug = product.id.split('/').pop()!;
      paths.push({ params: { locale, slug } });
    }
  }

  return paths;
}

const { locale, slug } = Astro.params;
const { t } = useTranslations(locale!);

// 获取产品
const products = await getCollection('products', (entry) =>
  entry.id === `${locale}/${slug}`
);
const product = products[0];

// 如果产品不存在，返回 404
if (!product) {
  return Astro.redirect(`/${locale}/products/`);
}

const p = product.data;

// 关联产品（同分类、不同 slug）
const relatedProducts = (await getCollection('products', (entry) =>
  entry.id.startsWith(`${locale}/`) &&
  entry.data.category === p.category &&
  entry.id !== `${locale}/${slug}`
)).slice(0, 3);

// Product Schema
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: p.title,
  description: p.description,
  image: p.image,
  manufacturer: {
    '@type': 'Organization',
    name: SITE.name,
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
  },
};

// Schema 组织（带面包屑）
const fullSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    schema,
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: t('nav.home'),
          item: `${SITE.url}/${locale}/`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: t('nav.products'),
          item: `${SITE.url}/${locale}/products/`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: p.title,
        },
      ],
    },
  ],
};

// 产品分类名
const categoryName = PRODUCT_CATEGORIES.find(c => c.slug === p.category);
---

<BaseLayout
  title={p.title}
  description={p.description}
  locale={locale!}
  image={p.image}
  schema={fullSchema}
>
  <div class="container-main section-padding">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-neutral-500 mb-8" aria-label="Breadcrumb">
      <a href={`/${locale}/`} class="hover:text-primary-600">{t('nav.home')}</a>
      <span>/</span>
      <a href={`/${locale}/products/`} class="hover:text-primary-600">{t('nav.products')}</a>
      <span>/</span>
      {categoryName && (
        <>
          <a href={`/${locale}/products/?category=${p.category}`} class="hover:text-primary-600">
            {t(categoryName.nameKey)}
          </a>
          <span>/</span>
        </>
      )}
      <span class="text-neutral-800 font-medium truncate">{p.title}</span>
    </nav>

    <!-- Product Main -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-16">
      <!-- Images -->
      <div>
        <div class="aspect-square rounded-xl overflow-hidden bg-white mb-4 cursor-zoom-in" id="mainImageContainer">
          <img
            id="mainImage"
            src={p.image}
            alt={p.title}
            class="w-full h-full object-contain p-4"
            width="800"
            height="800"
          />
        </div>
        {p.images && p.images.length > 0 && (
          <div class="grid grid-cols-4 gap-3" id="thumbnailList">
            {p.images.map((img, i) => (
              <div class="aspect-square rounded-lg overflow-hidden bg-neutral-100 border-2 border-transparent hover:border-primary-400 cursor-pointer transition-colors thumbnail-item" data-src={img}>
                <img
                  src={img}
                  alt={`${p.title} - View ${i + 2}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="200"
                  height="200"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Lightbox Modal -->
      <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 hidden flex-col items-center justify-center" style="display:none;">
        <button id="lightboxClose" class="absolute top-4 right-4 text-white/80 hover:text-white text-3xl leading-none cursor-pointer z-10">&times;</button>
        <button id="lightboxPrev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white text-3xl leading-none cursor-pointer z-10">&lsaquo;</button>
        <button id="lightboxNext" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white text-3xl leading-none cursor-pointer z-10">&rsaquo;</button>
        <img id="lightboxImage" src="" alt={p.title} class="max-w-[90vw] max-h-[85vh] object-contain" />
        <span id="lightboxCounter" class="text-white/60 text-sm mt-4"></span>
      </div>

      <!-- Product Info -->
      <div>
        {categoryName && (
          <span class="inline-block text-sm font-medium text-primary-600 uppercase tracking-wide mb-2">
            {t(categoryName.nameKey)}
          </span>
        )}
        <h1 class="mb-3">{p.title}</h1>
        <p class="text-lg text-neutral-600 leading-relaxed mb-6">{p.description}</p>

        <!-- Quick Info -->
        <div class="grid grid-cols-2 gap-4 mb-8 p-4 bg-neutral-50 rounded-lg">
          {p.moq && (
            <div>
              <span class="text-xs text-neutral-500 uppercase tracking-wide">{t('product.moq')}</span>
              <p class="font-semibold text-neutral-900">{p.moq}</p>
            </div>
          )}
          {p.deliveryTime && (
            <div>
              <span class="text-xs text-neutral-500 uppercase tracking-wide">{t('product.deliveryTime')}</span>
              <p class="font-semibold text-neutral-900">{p.deliveryTime}</p>
            </div>
          )}
          {p.certifications && p.certifications.length > 0 && (
            <div class="col-span-2">
              <span class="text-xs text-neutral-500 uppercase tracking-wide">{t('product.certifications')}</span>
              <div class="flex flex-wrap gap-2 mt-1">
                {p.certifications.map((cert) => (
                  <span class="inline-flex items-center gap-1 text-xs font-medium bg-accent-100 text-accent-700 px-2.5 py-1 rounded-full">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    {cert}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- CTA -->
        <div class="bg-accent-50 border border-accent-200 rounded-xl p-5 mb-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-sm font-medium text-accent-700">We respond within 24 hours</span>
          </div>
          <a href={`/${locale}/get-quote/?product=${encodeURIComponent(p.title)}`} class="btn-accent w-full text-center text-lg py-3.5 mb-2">
            📩 {t('product.getQuoteForProduct')} →
          </a>
          <p class="text-xs text-neutral-500 text-center">Free consultation · No commitment · Custom OEM pricing</p>
        </div>

        <!-- WhatsApp Quick -->
        <a
          href={`https://wa.me/${SITE.whatsapp.replace(/\+/g, '')}?text=${encodeURIComponent(`Hi, I'm interested in ${p.title}`)}`}
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-2 text-sm text-neutral-500 hover:text-accent-600 transition-colors py-2"
        >
          💬 Quick Chat via WhatsApp
        </a>
      </div>
    </div>

    <!-- Features & Specs Tabs -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-16">
      <!-- Key Features -->
      {p.features && p.features.length > 0 && (
        <div>
          <h2 class="mb-4 text-2xl">{t('product.features')}</h2>
          <ul class="space-y-3">
            {p.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-neutral-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Specifications -->
      {p.specifications && p.specifications.length > 0 && (
        <div>
          <h2 class="mb-4 text-2xl">{t('product.specifications')}</h2>
          <div class="border border-neutral-200 rounded-lg overflow-hidden">
            <table class="w-full">
              <tbody>
                {p.specifications.map((spec) => (
                  <tr class="border-b border-neutral-100 last:border-0">
                    <td class="px-4 py-3 text-sm font-medium text-neutral-700 bg-neutral-50 w-2/5">{spec.name}</td>
                    <td class="px-4 py-3 text-sm text-neutral-600">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>

    <!-- Customization Options -->
    {p.customOptions && p.customOptions.length > 0 && (
      <div class="mb-16 bg-neutral-50 rounded-xl p-8">
        <h2 class="mb-4 text-2xl">{t('product.customOptions')}</h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {p.customOptions.map((option) => (
            <li class="flex items-center gap-2 text-neutral-700">
              <svg class="w-4 h-4 text-primary-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              {option}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <div class="mb-16">
        <h2 class="mb-6 text-2xl">{t('product.relatedProducts')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedProducts.map((rp) => (
            <a
              href={`/${locale}/products/${rp.id.split('/').pop()}/`}
              class="group flex items-center gap-4 p-4 bg-white rounded-lg border border-neutral-200 hover:border-primary-200 hover:shadow-sm transition-all no-underline"
            >
              <div class="w-20 h-20 rounded-md overflow-hidden bg-neutral-100 shrink-0">
                <img src={rp.data.image} alt={rp.data.title} class="w-full h-full object-cover" loading="lazy" width="80" height="80" />
              </div>
              <div>
                <h4 class="font-medium text-neutral-900 group-hover:text-primary-700 transition-colors text-sm">{rp.data.title}</h4>
                {rp.data.moq && <p class="text-xs text-neutral-500 mt-1">MOQ: {rp.data.moq}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Bottom CTA -->
    <div class="text-center bg-primary-600 text-white rounded-2xl p-10">
      <h2 class="text-white mb-2">Interested in {p.title}?</h2>
      <p class="text-white/80 mb-6 max-w-xl mx-auto">
        Get a customized quote within 24 hours. We offer OEM customizations to match your brand requirements.
      </p>
      <a href={`/${locale}/get-quote/?product=${encodeURIComponent(p.title)}`} class="btn-white text-lg">
        {t('product.getQuoteForProduct')} →
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // --- Product Image Gallery ---
  const mainImg = document.getElementById('mainImage') as HTMLImageElement | null;
  const mainContainer = document.getElementById('mainImageContainer');
  const thumbnails = document.querySelectorAll('.thumbnail-item');
  const allImages: string[] = [];

  // Collect all image URLs (main + thumbnails)
  if (mainImg) allImages.push(mainImg.src);
  thumbnails.forEach((t) => {
    const src = (t as HTMLElement).dataset.src;
    if (src) allImages.push(src);
  });

  let currentIndex = 0;

  // Thumbnail click → switch main image
  thumbnails.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const src = (thumb as HTMLElement).dataset.src;
      if (src && mainImg) {
        mainImg.src = src;
        mainImg.style.opacity = '0';
        setTimeout(() => { mainImg.style.opacity = '1'; }, 50);
        mainImg.style.transition = 'opacity 0.3s ease';

        // Highlight active thumbnail
        thumbnails.forEach(t => (t as HTMLElement).style.borderColor = 'transparent');
        (thumb as HTMLElement).style.borderColor = '#2563eb';
      }
    });
  });

  // --- Lightbox ---
  const lightbox = document.getElementById('lightbox') as HTMLElement | null;
  const lightboxImg = document.getElementById('lightboxImage') as HTMLImageElement | null;
  const lightboxCounter = document.getElementById('lightboxCounter');
  const lightboxClose = document.getElementById('lightboxClose');
  const lightboxPrev = document.getElementById('lightboxPrev');
  const lightboxNext = document.getElementById('lightboxNext');

  function openLightbox(index: number) {
    if (!lightbox || !lightboxImg) return;
    currentIndex = index;
    lightboxImg.src = allImages[currentIndex];
    if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${allImages.length}`;
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  // Main image click → open lightbox
  mainContainer?.addEventListener('click', () => {
    // Find current index
    const idx = mainImg ? allImages.indexOf(mainImg.src) : 0;
    openLightbox(idx >= 0 ? idx : 0);
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  lightboxPrev?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + allImages.length) % allImages.length;
    if (lightboxImg) lightboxImg.src = allImages[currentIndex];
    if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${allImages.length}`;
  });

  lightboxNext?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % allImages.length;
    if (lightboxImg) lightboxImg.src = allImages[currentIndex];
    if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${allImages.length}`;
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.style.display === 'none') return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxPrev?.click();
    if (e.key === 'ArrowRight') lightboxNext?.click();
  });
</script>
