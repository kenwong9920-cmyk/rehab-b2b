---
// LanguageSwitcher — 语言切换下拉菜单
import { LANGUAGES, type LocaleCode } from '@/utils/constants';
const currentLocale = Astro.url.pathname.split('/')[1] || 'en';
---

<div class="relative group" id="lang-switcher">
  <button
    type="button"
    class="flex items-center gap-1 px-2 py-1.5 rounded-md text-sm text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 transition-colors"
    aria-label="Switch language"
  >
    <span class="text-base">
      {LANGUAGES.find(l => l.code === currentLocale)?.flag || '🌐'}
    </span>
    <span class="hidden sm:inline font-medium">{currentLocale.toUpperCase()}</span>
    <svg class="w-3.5 h-3.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div
    class="absolute right-0 top-full mt-1 bg-white rounded-lg shadow-lg border border-neutral-200 py-1 w-40 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
  >
    {LANGUAGES.map((lang) => {
      const pathParts = Astro.url.pathname.split('/').filter(Boolean);
      // 替换第一个路径段（locale）为目标语言
      const remaining = pathParts.slice(1).join('/');
      const targetPath = remaining ? `/${lang.code}/${remaining}/` : `/${lang.code}/`;
      const isActive = lang.code === currentLocale;
      return (
        <a
          href={targetPath}
          class={`flex items-center gap-2 px-4 py-2 text-sm transition-colors ${
            isActive ? 'bg-primary-50 text-primary-700 font-medium' : 'text-neutral-700 hover:bg-neutral-50'
          }`}
        >
          <span class="text-base">{lang.flag}</span>
          <span>{lang.label}</span>
          {isActive && <span class="ml-auto text-primary-500">✓</span>}
        </a>
      );
    })}
  </div>
</div>
