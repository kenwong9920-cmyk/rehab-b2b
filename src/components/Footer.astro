---
import { SITE, PRODUCT_CATEGORIES } from '@/utils/constants';

const locale = Astro.url.pathname.split('/')[1] || 'en';
const currentYear = new Date().getFullYear();

// Footer link groups
const companyLinks = [
  { href: `/${locale}/about/`, label: 'About Us' },
  { href: `/${locale}/factory/`, label: 'Our Factory' },
  { href: `/${locale}/oem-odm/`, label: 'OEM/ODM' },
  { href: `/${locale}/case-studies/`, label: 'Case Studies' },
];

const resourceLinks = [
  { href: `/${locale}/blog/`, label: 'Blog & Insights' },
  { href: `/${locale}/downloads/`, label: 'Downloads' },
  { href: `/${locale}/solutions/`, label: 'Solutions' },
  { href: `/${locale}/get-quote/`, label: 'Request Quote' },
];

const productLinks = PRODUCT_CATEGORIES.slice(0, 4).map((cat) => ({
  href: `/${locale}/products/${cat.slug}/`,
  label: cat.nameKey,
}));

const certifications = SITE.certifications.join(' · ');
---

<footer class="bg-neutral-900 text-neutral-300">
  <!-- Main Footer -->
  <div class="container-main py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company -->
      <div>
        <h4 class="text-white text-lg font-semibold mb-4 font-sans">{SITE.name}</h4>
        <p class="text-sm text-neutral-400 leading-relaxed mb-4">
          {SITE.tagline}. {SITE.certifications.join(' / ')} certified factory with {SITE.factoryArea} facility.
        </p>
        <div class="flex items-center gap-3">
          {SITE.social.linkedin && (
            <a href={SITE.social.linkedin} target="_blank" rel="noopener" class="text-neutral-400 hover:text-white transition-colors" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
          {SITE.social.facebook && (
            <a href={SITE.social.facebook} target="_blank" rel="noopener" class="text-neutral-400 hover:text-white transition-colors" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {SITE.social.youtube && (
            <a href={SITE.social.youtube} target="_blank" rel="noopener" class="text-neutral-400 hover:text-white transition-colors" aria-label="YouTube">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Products -->
      <div>
        <h4 class="text-white text-lg font-semibold mb-4 font-sans">Products</h4>
        <ul class="space-y-2.5">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-neutral-400 hover:text-white transition-colors no-underline">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href={`/${locale}/products/`} class="text-sm text-primary-400 hover:text-primary-300 transition-colors no-underline font-medium">
              View All →
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-white text-lg font-semibold mb-4 font-sans">Resources</h4>
        <ul class="space-y-2.5">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-neutral-400 hover:text-white transition-colors no-underline">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white text-lg font-semibold mb-4 font-sans">Contact</h4>
        <ul class="space-y-3 text-sm text-neutral-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{SITE.address.full}</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${SITE.email}`} class="text-neutral-400 hover:text-white transition-colors">{SITE.email}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${SITE.salesEmail}`} class="text-neutral-400 hover:text-white transition-colors">{SITE.salesEmail}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href={`https://wa.me/${SITE.whatsapp.replace(/\+/g, '')}`} target="_blank" rel="noopener" class="text-neutral-400 hover:text-white transition-colors">
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-neutral-800">
    <div class="container-main py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-500">
        &copy; {currentYear} {SITE.name}. All rights reserved.
      </p>
      <p class="text-xs text-neutral-600">
        {certifications}
      </p>
    </div>
  </div>
</footer>
