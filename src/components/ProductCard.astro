---
// ProductCard — 产品卡片
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
  category?: string;
  moq?: string;
}

const { title, description, image, href, category, moq } = Astro.props;
---

<div class="bg-white rounded-xl border border-neutral-200 overflow-hidden hover:shadow-lg hover:border-primary-200 transition-all duration-300 group flex flex-col">
  <a href={href} class="block aspect-[4/3] overflow-hidden bg-neutral-100">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      width="400"
      height="300"
    />
  </a>
  <div class="p-5 flex flex-col flex-1">
    {category && <span class="text-xs font-medium text-primary-600 uppercase tracking-wide mb-2">{category}</span>}
    <a href={href} class="no-underline">
      <h3 class="text-lg font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors mb-2">
        {title}
      </h3>
    </a>
    <p class="text-sm text-neutral-600 leading-relaxed flex-1 mb-4 line-clamp-2">{description}</p>
    <div class="flex items-center justify-between pt-3 border-t border-neutral-100">
      {moq && <span class="text-xs text-neutral-500">MOQ: {moq}</span>}
      <a href={href} class="btn-primary btn-sm ml-auto">
        Get Quote
      </a>
    </div>
  </div>
</div>
