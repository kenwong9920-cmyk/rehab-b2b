---
// ContactForm — 通用联系表单
interface Props {
  productName?: string;
  showProductField?: boolean;
  showQuantityField?: boolean;
}

const { productName = '', showProductField = false, showQuantityField = false } = Astro.props;
const locale = Astro.url.pathname.split('/')[1] || 'en';
---

<form
  id="inquiry-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-5"
>
  <!-- Web3Forms Access Key - Replace with your own -->
  <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
  <input type="hidden" name="subject" value={`New Inquiry from RehabPro Medical — ${productName || 'General'}`} />
  <input type="hidden" name="from_name" value="RehabPro Medical Website" />
  {/* Honeypot anti-spam */}
  <input type="checkbox" name="botcheck" class="hidden" style="display:none;" />
  <input type="hidden" name="redirect" value="false" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-sm font-medium text-neutral-700 mb-1.5">
        Full Name <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
        placeholder="John Smith"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-neutral-700 mb-1.5">
        Email <span class="text-red-500">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
        placeholder="john@company.com"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="company" class="block text-sm font-medium text-neutral-700 mb-1.5">Company</label>
      <input
        type="text"
        id="company"
        name="company"
        class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
        placeholder="Your Company Ltd."
      />
    </div>
    <div>
      <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1.5">
        Phone / WhatsApp
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
        placeholder="+1 (555) 000-0000"
      />
    </div>
  </div>

  {showProductField && (
    <div>
      <label for="product" class="block text-sm font-medium text-neutral-700 mb-1.5">Product of Interest</label>
      <input
        type="text"
        id="product"
        name="product"
        value={productName}
        class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
        placeholder="e.g., Electric Wheelchair EW-2000"
      />
    </div>
  )}

  {showQuantityField && (
    <div>
      <label for="quantity" class="block text-sm font-medium text-neutral-700 mb-1.5">Estimated Quantity</label>
      <input
        type="text"
        id="quantity"
        name="quantity"
        class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm"
        placeholder="e.g., 100 units"
      />
    </div>
  )}

  <div>
    <label for="message" class="block text-sm font-medium text-neutral-700 mb-1.5">
      Your Requirements <span class="text-red-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="4"
      required
      class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-shadow text-sm resize-y"
      placeholder="Tell us about your needs, target market, custom requirements..."
    ></textarea>
  </div>

  <button type="submit" class="btn-accent w-full text-lg py-3.5">
    Submit Inquiry →
  </button>

  <p class="text-xs text-neutral-400 text-center">
    We respect your privacy. Your information will never be shared with third parties.
  </p>
</form>

<script>
  // Simple form submission handler with feedback
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const originalText = btn?.textContent || 'Submit';
    if (btn) {
      btn.textContent = 'Sending...';
      btn.disabled = true;
    }

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        form.innerHTML = '<div class="text-center py-8"><div class="text-4xl mb-4">✅</div><h3 class="text-xl font-semibold text-accent-700 mb-2">Thank You!</h3><p class="text-neutral-600">We will contact you within 24 hours.</p></div>';
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      if (btn) {
        btn.textContent = originalText;
        btn.disabled = false;
      }
      alert('Something went wrong. Please try again or email us directly at info@rehabpro-med.com');
    }
  });
</script>
