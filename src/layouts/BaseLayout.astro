---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description: string;
  locale: string;
  image?: string;
  schema?: object;
}

const { title, description, locale = 'en', image = '/og-image.png', schema } = Astro.props;
const siteName = 'JinDa Rehab Medical';
const currentUrl = Astro.url.href;
const imageUrl = new URL(image, Astro.url).href;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={currentUrl} />

  <!-- Hreflang for multilingual SEO -->
  <link rel="alternate" hreflang="en" href={currentUrl.replace(`/${locale}/`, '/en/')} />
  <link rel="alternate" hreflang="fr" href={currentUrl.replace(`/${locale}/`, '/fr/')} />
  <link rel="alternate" hreflang="de" href={currentUrl.replace(`/${locale}/`, '/de/')} />
  <link rel="alternate" hreflang="es" href={currentUrl.replace(`/${locale}/`, '/es/')} />
  <link rel="alternate" hreflang="ko" href={currentUrl.replace(`/${locale}/`, '/ko/')} />
  <link rel="alternate" hreflang="ja" href={currentUrl.replace(`/${locale}/`, '/ja/')} />
  <link rel="alternate" hreflang="x-default" href={currentUrl.replace(`/${locale}/`, '/en/')} />

  <!-- Primary Meta -->
  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="rehabilitation equipment manufacturer, medical equipment wholesale, walking aids, shower chair, commode chair, OEM rehabilitation products, {title}" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:title" content={`${title} | ${siteName}`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content={locale} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ${siteName}`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-S0VYYJJBM1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-S0VYYJJBM1');
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700;900&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD Structured Data -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body class="flex flex-col min-h-screen bg-white">
  <Header />

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Floating WhatsApp Button -->
  <a
    href="https://wa.me/85257044967?text=Hi%2C%20I%27m%20interested%20in%20your%20rehabilitation%20products"
    target="_blank"
    rel="noopener"
    class="fixed bottom-24 right-6 z-40 w-14 h-14 rounded-full bg-[#25D366] text-white shadow-lg hover:shadow-xl hover:scale-110 transition-all duration-300 flex items-center justify-center group"
    aria-label="Chat on WhatsApp"
  >
    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full border-2 border-white"></span>
    <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 bg-neutral-800 text-white text-xs px-3 py-1.5 rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
      Chat on WhatsApp
    </span>
  </a>
  <!-- Tawk.to Live Chat -->
  <script type="text/javascript">
    var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
    (function(){
    var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
    s1.async=true;
    s1.src='https://embed.tawk.to/6a1c44bb75643d1c2d678e65/1jpv6ovq1';
    s1.charset='UTF-8';
    s1.setAttribute('crossorigin','*');
    s0.parentNode.insertBefore(s1,s0);
    })();
  </script>

  <!-- Vercel Speed Insights -->
  <SpeedInsights />
</body>
</html>
